# Ops Agent v3.0 Configuration (DeepAgents)
#
# 配置说明：
# - 此文件包含需要重启服务才能生效的配置
# - 运行时可动态修改的配置已移至数据库系统设置（通过 Web 管理后台配置）
#
# 系统设置包含：
# - 飞书聊天模式、拒绝消息、意图分类参数
# - LLM 温度参数
# - 功能开关（V2 巡检、自愈、安全审核）
# - K8s/Prometheus/Loki 启用开关和服务地址
# - 测试配置（Mock 数据开关）

# ========== Application ==========
APP_NAME="Ops Agent LangGraph"
DEBUG=false
LOG_LEVEL=INFO

# ========== Database ==========
DATABASE_URL=sqlite:///./data/ops_agent_v2.db
# 默认复用主库；只有确实需要独立 checkpoint 库时才显式配置
# CHECKPOINT_DB_URL=sqlite:///./data/checkpoints/langgraph.db

# ========== LLM Provider ==========
DEFAULT_LLM_PROVIDER=openai  # openai, claude, zhipu, ollama, openrouter

# OpenRouter (聚合 LLM 服务 - 推荐)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TEMPERATURE=0.0
OPENROUTER_MAX_TOKENS=4096
OPENROUTER_REQUEST_TIMEOUT=120

# OpenAI
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TEMPERATURE=0.0
OPENAI_MAX_TOKENS=4096
OPENAI_REQUEST_TIMEOUT=120

# Claude
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-sonnet-20240229
CLAUDE_TEMPERATURE=0.0
CLAUDE_MAX_TOKENS=4096
CLAUDE_REQUEST_TIMEOUT=120

# 智谱 AI (ZhipuAI)
ZHIPU_API_KEY=
ZHIPU_MODEL=glm-4  # glm-4, glm-4-plus, glm-4-flash
ZHIPU_TEMPERATURE=0.0
ZHIPU_MAX_TOKENS=4096
ZHIPU_REQUEST_TIMEOUT=120

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_TEMPERATURE=0.0

# ========== Feishu Integration ==========
FEISHU_ENABLED=true
FEISHU_APP_ID=cli_xxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxx
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxx
FEISHU_VERIFICATION_TOKEN=xxxxxxxxxxxxx
FEISHU_CHAT_ID=oc_xxxxxxxxxxxxx
FEISHU_ENCRYPT_KEY=

# Feishu connection mode (需要重启)
FEISHU_CONNECTION_MODE=auto  # webhook | longconn | auto
FEISHU_LONGCONN_HEARTBEAT_INTERVAL=30
FEISHU_LONGCONN_RECONNECT_INTERVAL=5
FEISHU_LONGCONN_MAX_RECONNECT_ATTEMPTS=10

# Feishu 运行时配置（可在系统设置中动态修改）
# 以下配置仅作为初始值，实际运行时从数据库读取
FEISHU_CHAT_MODE=command_only  # ai_chat | command_only
FEISHU_REJECT_MESSAGE=有事说事，没事退朝，运维AI，拒绝闲聊
FEISHU_ENABLE_INTENT_CLASSIFICATION=true
FEISHU_INTENT_THRESHOLD=0.5

# ========== Kubernetes (可在系统设置中动态修改) ==========
K8S_ENABLED=false
KUBECONFIG=

# ========== Prometheus (可在系统设置中动态修改) ==========
PROMETHEUS_ENABLED=false
PROMETHEUS_URL=

# ========== Loki (可在系统设置中动态修改) ==========
LOKI_ENABLED=false
LOKI_URL=

# ========== Security Policy ==========
SECURITY_POLICY_PATH=./config/security_policy.yaml
SECURITY_ENVIRONMENT=production  # production | testing | development

# ========== JWT 配置 ==========
JWT_SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_ACCESS_TOKEN_EXPIRE_DAYS=7

# ========== 初始管理员账号 ==========
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=admin123
INITIAL_ADMIN_EMAIL=admin@ops-agent.local

# ========== Feature Flags (可在系统设置中动态修改) ==========
DEFAULT_WORKFLOW_VERSION=v1
V2_INSPECTION_ENABLED=false
V2_HEALING_ENABLED=false
V2_SECURITY_ENABLED=true
V2_PLUGINS=

# ========== API & CORS ==========
ENABLE_DOCS=false
ENABLE_CORS=false
CORS_ORIGINS=

# ========== Performance ==========
WORKERS=4
TIMEOUT=120

# ========== Mock Data (可在系统设置中动态修改) ==========
USE_MOCK_DATA=false

# ========== Subagent LLM Configuration ==========
# 所有子智能体使用 DEFAULT_LLM_PROVIDER，只需配置模型名称
SUBAGENT_INTENT_MODEL=glm-4-flash
SUBAGENT_ANALYZE_MODEL=glm-4
SUBAGENT_DATA_MODEL=glm-4
SUBAGENT_EXECUTE_MODEL=glm-4
SUBAGENT_REPORT_MODEL=glm-4
SUBAGENT_FORMAT_MODEL=glm-4-flash

# ========== Mem0 记忆系统配置 ==========
# Mem0 提供通用对话记忆（用户偏好、会话上下文）
# 与 MemoryManager 配合：Mem0 负责通用对话，MemoryManager 负责运维领域
#
# 重要：Mem0 会自动复用主 Agent 的 LLM 配置（DEFAULT_LLM_PROVIDER）
# - 如果 DEFAULT_LLM_PROVIDER=openai，使用 OPENAI_API_KEY + OPENAI_MODEL
# - 如果 DEFAULT_LLM_PROVIDER=ollama，使用 OLLAMA_BASE_URL + OLLAMA_MODEL
# - 如果 DEFAULT_LLM_PROVIDER=claude，使用 CLAUDE_API_KEY + CLAUDE_MODEL
# - 如果 DEFAULT_LLM_PROVIDER=zhipu，使用 ZHIPU_API_KEY + ZHIPU_MODEL
#
# MEM0_PROVIDER 只在需要与主 Agent 使用不同模型时才需要设置
MEM0_ENABLED=true                 # 启用 Mem0 通用对话记忆
# MEM0_API_KEY=                   # Mem0 Platform API Key（留空=自托管模式，推荐）
# MEM0_PROVIDER=                  # LLM 提供商（留空=使用 DEFAULT_LLM_PROVIDER）
# MEM0_MODEL=                     # 模型名称（留空=使用对应 provider 的默认模型）
MEM0_AUTO_LEARN=true              # 是否自动从对话中学习
