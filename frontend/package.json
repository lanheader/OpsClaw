{
  "name": "ops-agent-web",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Ops Agent v3.0 Web Management Interface",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
